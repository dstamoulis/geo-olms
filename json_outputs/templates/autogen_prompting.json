{
    "provider": "autogen",
    "component_type": "Workflow",
    "version": 1,
    "component_version": 1,
    "description": "Agentic workflow to fetch satellite images, run a detector, and zoom the map for Athens International Airport, Greece.",
    "label": "Athens Airport Image Processing Workflow",
    "config": {
        "participants": [
            {
                "provider": "autogen",
                "component_type": "Agent",
                "version": 1,
                "component_version": 1,
                "description": "Agent to fetch xView1 images from a specified area.",
                "label": "ImageFetcherAgent",
                "config": {
                    "name": "ImageFetcher",
                    "model_client": {
                        "provider": "autogen",
                        "component_type": "ModelClient",
                        "version": 1,
                        "component_version": 1,
                        "description": "Client for fetching satellite images",
                        "label": "ImageClient",
                        "config": {
                            "model": "xView1ImageFetcher"
                        }
                    },
                    "tools": [
                        "image_fetcher_tool"
                    ],
                    "handoffs": [
                        "RunSwinLDetection"
                    ],
                    "model_context": {
                        "provider": "autogen",
                        "component_type": "ModelContext",
                        "version": 1,
                        "component_version": 1,
                        "description": "Context for the image-fetching agent",
                        "label": "ImageFetchContext",
                        "config": {
                            "model": "xView1FetcherContext"
                        }
                    },
                    "description": "Fetches xView1 images from specified coordinates in Athens",
                    "system_message": "You will fetch satellite images from Athens International Airport.",
                    "model_client_stream": false,
                    "reflect_on_tool_use": true,
                    "tool_call_summary_format": "Fetched images from the xView1 dataset."
                }
            },
            {
                "provider": "autogen",
                "component_type": "Agent",
                "version": 1,
                "component_version": 1,
                "description": "Agent to run Swin-L detector on images.",
                "label": "SwinLDetectorAgent",
                "config": {
                    "name": "SwinLDetector",
                    "model_client": {
                        "provider": "autogen",
                        "component_type": "ModelClient",
                        "version": 1,
                        "component_version": 1,
                        "description": "Client for running the Swin-L detector",
                        "label": "SwinLClient",
                        "config": {
                            "model": "Swin-L"
                        }
                    },
                    "tools": [
                        "swin_l_detector_tool"
                    ],
                    "handoffs": [
                        "ZoomMap"
                    ],
                    "model_context": {
                        "provider": "autogen",
                        "component_type": "ModelContext",
                        "version": 1,
                        "component_version": 1,
                        "description": "Context for the Swin-L detection agent",
                        "label": "SwinLDetectorContext",
                        "config": {
                            "model": "SwinLContext"
                        }
                    },
                    "description": "Processes fetched images and runs the Swin-L object detection model.",
                    "system_message": "You will analyze the fetched images with the Swin-L detector.",
                    "model_client_stream": false,
                    "reflect_on_tool_use": true,
                    "tool_call_summary_format": "Processed images with Swin-L detector."
                }
            },
            {
                "provider": "autogen",
                "component_type": "Agent",
                "version": 1,
                "component_version": 1,
                "description": "Agent to zoom the map at the specified location.",
                "label": "MapZoomAgent",
                "config": {
                    "name": "MapZoomer",
                    "model_client": {
                        "provider": "autogen",
                        "component_type": "ModelClient",
                        "version": 1,
                        "component_version": 1,
                        "description": "Client for map operations",
                        "label": "MapClient",
                        "config": {
                            "model": "MapZoomer"
                        }
                    },
                    "tools": [
                        "map_zoom_tool"
                    ],
                    "handoffs": [],
                    "model_context": {
                        "provider": "autogen",
                        "component_type": "ModelContext",
                        "version": 1,
                        "component_version": 1,
                        "description": "Context for the map zooming agent",
                        "label": "MapZoomContext",
                        "config": {
                            "model": "MapContext"
                        }
                    },
                    "description": "Zooms the map view to the location of Athens International Airport.",
                    "system_message": "You will zoom the map to the area of Athens International Airport, Greece.",
                    "model_client_stream": false,
                    "reflect_on_tool_use": true,
                    "tool_call_summary_format": "Zoomed the map to Athens International Airport."
                }
            }
        ],
        "termination_condition": {
            "provider": "autogen",
            "component_type": "TerminationCondition",
            "version": 1,
            "component_version": 1,
            "description": "Ends the workflow when all agents have completed their tasks.",
            "label": "CompletionCondition",
            "config": {
                "text": "All tasks have been completed."
            }
        }
    }
}